generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  fullName      String
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  role          String         @default("member")
  avatarUrl     String?
  suspended     Boolean        @default(false)
  bookings      Booking[]
  claimedConvos Conversation[] @relation("ClaimedConversations")
  conversations Conversation[] @relation("UserConversations")
  drafts        Draft[]
  sentMessages  Message[]      @relation("SentMessages")
  notifications Notification[]
  reviews       Review[]
}

model Draft {
  id          String   @id @default(cuid())
  userId      String
  formData    Json
  lastSavedAt DateTime @updatedAt
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  comment   String
  rating    Int
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  bookingId Int?     @unique
  booking   Booking? @relation(fields: [bookingId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id          String    @id @default(cuid())
  userId      String
  subject     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  claimedById String?
  status      Status    @default(OPEN)
  claimedBy   User?     @relation("ClaimedConversations", fields: [claimedById], references: [id])
  user        User      @relation("UserConversations", fields: [userId], references: [id])
  messages    Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
}

model Booking {
  fullName         String
  email            String
  phone            String
  activity         String
  participants     Int            @default(1)
  date             DateTime?
  timeSlot         String?
  allergies        String?
  specialRequests  String?
  additionalNotes  String?
  preferredContact String         @default("telephone")
  activityTheme    String?
  createdAt        DateTime       @default(now())
  status           String         @default("pending")
  userId           String?
  id               Int            @id @default(autoincrement())
  advancePaid      Float?
  paidAt           DateTime?
  paymentStatus    String         @default("PENDING")
  user             User?          @relation(fields: [userId], references: [id])
  notifications    Notification[]
  review           Review?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  bookingId Int?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  booking   Booking? @relation(fields: [bookingId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Status {
  OPEN
  CLOSED
}
