generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  fullName         String
  email            String
  phone            String
  activity         String
  participants     Int            @default(1)
  date             DateTime?
  timeSlot         String?
  allergies        String?
  specialRequests  String?
  additionalNotes  String?
  preferredContact String         @default("telephone")
  activityTheme    String?
  createdAt        DateTime       @default(now())
  status           String         @default("pending")
  userId           String?
  id               Int            @id @default(autoincrement())
  advancePaid      Float?
  paidAt           DateTime?
  paymentStatus    String         @default("PENDING")
  User             User?          @relation(fields: [userId], references: [id])
  Notification     Notification[]
  Review           Review?
}

model Conversation {
  id                                  String    @id
  userId                              String
  subject                             String?
  createdAt                           DateTime  @default(now())
  updatedAt                           DateTime
  claimedById                         String?
  status                              Status    @default(OPEN)
  User_Conversation_claimedByIdToUser User?     @relation("Conversation_claimedByIdToUser", fields: [claimedById], references: [id])
  User_Conversation_userIdToUser      User      @relation("Conversation_userIdToUser", fields: [userId], references: [id])
  Message                             Message[]
}

model Draft {
  id          String   @id
  userId      String
  formData    Json
  lastSavedAt DateTime
  createdAt   DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String       @id
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())
  readAt         DateTime?
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [senderId], references: [id])
}

model Notification {
  id        String   @id
  userId    String
  bookingId Int?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  Booking   Booking? @relation(fields: [bookingId], references: [id])
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id
  userId    String
  comment   String
  rating    Int
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  bookingId Int?     @unique
  Booking   Booking? @relation(fields: [bookingId], references: [id])
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                                          String         @id
  fullName                                    String
  email                                       String         @unique
  password                                    String
  createdAt                                   DateTime       @default(now())
  role                                        String         @default("member")
  avatarUrl                                   String?
  suspended                                   Boolean        @default(false)
  Booking                                     Booking[]
  Conversation_Conversation_claimedByIdToUser Conversation[] @relation("Conversation_claimedByIdToUser")
  Conversation_Conversation_userIdToUser      Conversation[] @relation("Conversation_userIdToUser")
  Draft                                       Draft[]
  Message                                     Message[]
  Notification                                Notification[]
  Review                                      Review[]
}

enum Status {
  OPEN
  CLOSED
}
