generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ✅ Enum from Hasna's code
enum Status {
  OPEN
  CLOSED
}

model User {
  id                String             @id @default(cuid())
  fullName          String
  email             String             @unique
  password          String
  role              String             @default("member")
  suspended         Boolean            @default(false)
  avatarUrl         String?
  createdAt         DateTime           @default(now())
  drafts            Draft[]
  reviews           Review[]
  conversations     Conversation[]     @relation("UserConversations")
  claimedConvos     Conversation[]     @relation("ClaimedConversations")
  sentMessages      Message[]          @relation("SentMessages")
  bookings          Booking[]
  notifications     Notification[]
}

model Draft {
  id          String   @id @default(cuid())
  userId      String
  formData    Json
  lastSavedAt DateTime @updatedAt
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  bookingId Int?     @unique   // ← was gatheringRequestId String?
  comment   String
  rating    Int
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
}

// ✅ Changed Int → String cuid() to match all other models
model Conversation {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserConversations", fields: [userId], references: [id])
  subject     String?
  status      Status    @default(OPEN)
  claimedById String?
  claimedBy   User?     @relation("ClaimedConversations", fields: [claimedById], references: [id])
  messages    Message[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ✅ Changed Int → String cuid() + conversationId String
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  body           String
  createdAt      DateTime     @default(now())
  readAt         DateTime?
}

model Booking {
  id               Int       @id @default(autoincrement())
  fullName         String
  email            String
  phone            String
  activity         String
  participants     Int       @default(1)
  date             DateTime?
  timeSlot         String?
  allergies        String?
  specialRequests  String?
  additionalNotes  String?
  preferredContact String    @default("telephone")
  activityTheme    String?
  status           String    @default("pending")
  userId           String?
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  paymentStatus    String    @default("PENDING")
  advancePaid      Float?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  notifications    Notification[]
  review           Review?  
}

model Notification {
  id        String   @id @default(cuid())  // ✅ changed to cuid for consistency
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookingId Int?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}